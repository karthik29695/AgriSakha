# ================================================================
# AgriSakha – Environment Configuration Template
# ================================================================
# Copy this file to .env and fill in your actual API keys.
# The .env file is listed in .gitignore and will NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your real values
# ================================================================

# ----------------------------------------------------------------
# Gemini API Keys (Google AI Studio)
# Supports comma-separated list for automatic key rotation
# Get yours: https://aistudio.google.com/app/apikey
# ----------------------------------------------------------------
GEMINI_API_KEYS=your_gemini_api_key_here
# For rotation: GEMINI_API_KEYS=key_one,key_two,key_three

# ----------------------------------------------------------------
# OpenWeatherMap API Key
# Used for real-time weather data and farming advisories
# Get yours: https://openweathermap.org/api
# ----------------------------------------------------------------
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ----------------------------------------------------------------
# Data.gov.in API Key
# Used for live mandi (market) crop prices across India
# Get yours: https://data.gov.in/user/register
# ----------------------------------------------------------------
DATA_GOV_API_KEY=your_data_gov_api_key_here

# ----------------------------------------------------------------
# Server Configuration (optional)
# ----------------------------------------------------------------
PORT=5000
